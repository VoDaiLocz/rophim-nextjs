{
  "name": "rophim",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,tsx,json,md}\" \".github/**/*.{yml,yaml,md}\" \"render.yaml\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,tsx,json,md}\" \".github/**/*.{yml,yaml,md}\" \"render.yaml\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.1",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.9.0"
  }
}
